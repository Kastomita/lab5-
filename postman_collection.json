                "value": "Bearer {{accessToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"customerId\": 1,\n    \"photos\": [\n        {\n            \"fileName\": \"vacation.jpg\",\n            \"fileUrl\": \"https://example.com/vacation.jpg\",\n            \"quantity\": 2,\n            \"description\": \"Vacation photo\",\n            \"formatId\": 1\n        },\n        {\n            \"fileName\": \"family.jpg\",\n            \"fileUrl\": \"https://example.com/family.jpg\",\n            \"quantity\": 1,\n            \"description\": \"Family photo\",\n            \"formatId\": 2\n        }\n    ]\n}"
            },
            "url": {
